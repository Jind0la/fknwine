        <td style="padding: 0.75rem 0.5rem;">Lamm / Grillwürste</td>
        <td style="padding: 0.75rem 0.5rem;">Syrah Peloponnes <Icon name="wine" size={20} color="var(--color-primary)" /></td>
      </tr>
      <tr style="border-bottom: 1px solid var(--color-surface);">
        <td style="padding: 0.75rem 0.5rem;">Hähnchen / Geflügel</td>
