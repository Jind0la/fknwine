---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Datenschutz" description="Datenschutzerklärung FKN Wine">
  <section class="wrapper" style="padding-top: 4rem; padding-bottom: 4rem; max-width: 700px;">
    <h1 style="font-size: 2rem;">Datenschutzerklärung</h1>
    <p>Wir erheben und verarbeiten Ihre Daten nur im Rahmen der gesetzlichen Bestimmungen.</p>
    <p>
      Diese Website verwendet keine Tracking-Cookies. Kein Google Analytics. Kein Facebook Pixel.
      Cloudflare Web Analytics (datenschutzkonform, keine Cookies) wird für anonyme Besucherstatistiken genutzt.
    </p>
    <p style="margin-top: 2rem; font-size: 0.85rem; color: color-mix(in srgb, var(--color-text) 50%, transparent);">
      Stand: Juli 2026. Vollständige Datenschutzerklärung folgt.
    </p>
  </section>
</Layout>
