---
import Layout from '../layouts/Layout.astro';

const articles = [
  {
    title: 'Die 10 besten Weine unter €10 im Supermarkt',
    slug: 'beste-weine-unter-10-euro-supermarkt',
    date: '2026-07-06',
    excerpt: 'Wir haben 47 Supermarkt-Weine getestet. Hier sind die einzigen 10 die du kaufen solltest — null Gelaber, null Punkte-Skala.',
    tags: ['Supermarkt', 'Rotwein', 'Weißwein'],
  },
  {
    title: 'Aldi vs. Lidl vs. Edeka — wo kaufst du den besten Wein?',
    slug: 'aldi-lidl-edeka-wein-vergleich',
    date: '2026-07-04',
    excerpt: 'Discounter-Wein kann scheiße sein. Kann aber auch geil sein. Hier ist welcher Supermarkt für welchen Wein-Typ am besten funktioniert.',
    tags: ['Discounter', 'Vergleich'],
  },
  {
    title: 'Wein für Pizza — 5 Flaschen die besser sind als dein Standard-Chianti',
    slug: 'wein-fuer-pizza',
    date: '2026-06-28',
    excerpt: 'Chianti zur Pizza ist langweilig. Wir haben fünf Alternativen die deine TK-Salami aufs nächste Level bringen.',
    tags: ['Food-Pairing', 'Rotwein'],
  },
];
---

<Layout
  title="F*ck Nice Wine"
  description="FKN Wine — ehrliche Wein-Empfehlungen ohne Snob-Getue. Welcher Supermarkt-Wein ist wirklich gut? Find's raus."
>
  <!-- === HERO === -->
  <section class="wrapper" style="padding-top: 4rem; padding-bottom: 6rem;">
    <div style="display: grid; gap: 1rem; max-width: 800px;">
      <!-- Eyebrow -->
      <span
        class="brutal-border"
        style="display: inline-block; padding: 0.35rem 0.75rem; font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; background: var(--color-primary); color: var(--color-fkn-white); width: fit-content;"
      >
        Kein Snob. Kein Bullshit.
      </span>

      <h1 style="margin: 0;">
        F*CK
        <br />
        NICE
        <br />
        <span style="color: var(--color-primary);">WINE</span>
      </h1>

      <p style="font-size: 1.2rem; max-width: 600px; margin-top: 0.5rem;">
        Du willst geilen Wein trinken ohne dafür ein Sommelier-Zertifikat zu brauchen?
        Wir sagen dir was du kaufen sollst — und warum der €7-Wein von Aldi besser ist als die €25-Flasche aus dem Fachhandel.
      </p>

      <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem;">
        <a href="#articles" class="brutal-btn">Zum ersten Artikel</a>
        <a href="#about" class="brutal-btn brutal-btn--inverse">Was ist FKN Wine?</a>
      </div>
    </div>

    <!-- Decorative element -->
    <div
      aria-hidden="true"
      style="position: absolute; top: 8rem; right: 2rem; width: 200px; height: 200px; border: 3px solid var(--color-primary); transform: rotate(12deg); opacity: 0.3; pointer-events: none; display: none;"
      class="hero-deco"
    >
    </div>
  </section>

  <!-- === ARTICLES === -->
  <section id="articles" class="wrapper" style="padding-bottom: 4rem;">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem;">
      <h2 style="margin: 0; font-size: 1.75rem;">Neueste Artikel</h2>
      <span style="font-family: var(--font-display); font-size: 0.8rem; text-transform: uppercase; color: var(--color-primary); letter-spacing: 0.05em;">
        Frisch aus der Flasche
      </span>
    </div>

    <div style="display: grid; gap: 1.5rem;">
      {
        articles.map((article) => (
          <article class="brutal-card brutal-shadow-hover" style="cursor: pointer;">
            <a
              href={`/artikel/${article.slug}`}
              style="text-decoration: none; color: inherit; display: block;"
            >
              <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
                {article.tags.map((tag) => (
                  <span
                    style="font-family: var(--font-display); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.2rem 0.5rem; border: 2px solid var(--color-primary); color: var(--color-primary);"
                  >
                    {tag}
                  </span>
                ))}
              </div>
              <h3 style="font-size: 1.4rem; margin: 0.5rem 0 0.25rem;">
                {article.title}
              </h3>
              <p style="font-size: 0.95rem; margin: 0.25rem 0 0.5rem;">
                {article.excerpt}
              </p>
              <span style="font-family: var(--font-display); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-cta);">
                Weiterlesen →
              </span>
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <!-- === ABOUT === -->
  <section id="about" class="wrapper" style="padding-bottom: 4rem;">
    <div class="brutal-card" style="max-width: 700px;">
      <h2 style="font-size: 1.75rem; margin-top: 0;">Was ist FKN Wine?</h2>
      <p>
        Wein muss nicht teuer sein um geil zu schmecken. Und du musst kein Weinkenner sein um den richtigen Wein zu finden.
        FKN Wine ist für Leute die Bock auf Wein haben — aber null Bock auf die Wein-Snob-Kultur.
      </p>
      <p>
        Wir testen Supermarkt-Weine, Discounter-Flaschen und alles was du im Alltag tatsächlich kaufst.
        Keine €80-Bordeaux-Empfehlungen. Kein "Noten von nasser Schieferplatte"-Gelaber.
        Nur: <strong>Schmeckt geil. Kost €8. Kauf das.</strong>
      </p>
      <div style="margin-top: 1.5rem;">
        <span style="font-family: var(--font-display); font-weight: 700; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">
          🍷 F*ck Nice Wine.
        </span>
      </div>
    </div>
  </section>

  <!-- === NEWSLETTER === -->
  <section class="wrapper" style="padding-bottom: 2rem;">
    <div
      style="border: 3px solid var(--color-cta); padding: 2rem; text-align: center; box-shadow: 6px 6px 0 0 var(--color-cta); max-width: 600px; margin: 0 auto;"
    >
      <h2 style="font-size: 1.5rem; margin: 0 0 0.5rem;">Kein Bock zu suchen?</h2>
      <p style="margin: 0 0 1rem;">Krieg jeden Freitag eine Wein-Empfehlung in deine Inbox. Kostenlos. Kein Spam.</p>
      <div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
        <form action="https://buttondown.com/api/emails/embed-subscribe/fknwine" method="post" target="popupwindow" onsubmit="window.open('https://buttondown.com/fknwine', 'popupwindow')" style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
          <input
            type="email"
            name="email"
            placeholder="deine@email.de"
            required
            style="padding: 0.75rem 1rem; border: 3px solid var(--color-text); background: var(--color-surface); color: var(--color-text); font-family: var(--font-sans); font-size: 0.95rem; min-width: 200px;"
          />
          <button class="brutal-btn" type="submit" style="border-color: var(--color-cta);">
            Anmelden
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  @media (min-width: 768px) {
    .hero-deco {
      display: block;
    }
  }
</style>
