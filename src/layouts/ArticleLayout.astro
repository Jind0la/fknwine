---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';

// Static article template — will be replaced by content collections later
interface ArticleFrontmatter {
  title: string;
  date: string;
  description: string;
  tags: string[];
}

const frontmatter: ArticleFrontmatter = {
  title: Astro.props.title || 'Artikel',
  date: Astro.props.date || '2026-07-01',
  description: Astro.props.description || '',
  tags: Astro.props.tags || [],
};
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <article class="wrapper" style="padding-top: 3rem; padding-bottom: 4rem; max-width: 750px;">
    <!-- Article Header -->
    <header style="margin-bottom: 2rem;">
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
        {frontmatter.tags.map((tag: string) => (
          <span style="font-family: var(--font-display); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.2rem 0.5rem; border: 2px solid var(--color-primary); color: var(--color-primary);">
            {tag}
          </span>
        ))}
      </div>
      <h1 style="font-size: clamp(2rem, 5vw, 2.75rem); margin: 0 0 0.5rem;">
        {frontmatter.title}
      </h1>
      <time
        datetime={frontmatter.date}
        style="font-family: var(--font-display); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-primary);"
      >
        {new Date(frontmatter.date).toLocaleDateString('de-DE', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
    </header>

    <!-- Hero Image -->
    {Astro.props.heroImage && (
      <img
        src={Astro.props.heroImage}
        alt={frontmatter.title}
        style="width: 100%; height: auto; border: 3px solid var(--color-primary); box-shadow: 6px 6px 0 0 var(--color-primary); margin-bottom: 2rem;"
      />
    )}

    <!-- Article Content -->
    <div class="article-content">
      <slot />
    </div>

    <!-- Share / Newsletter Footer -->
    <footer style="margin-top: 3rem; padding-top: 1.5rem; border-top: 3px solid var(--color-surface);">
      <div
        style="border: 3px solid var(--color-cta); padding: 1.5rem; text-align: center; box-shadow: 4px 4px 0 0 var(--color-cta);"
      >
        <p style="margin: 0 0 0.75rem; font-family: var(--font-display); font-weight: 700; text-transform: uppercase; font-size: 0.9rem;">
          🍷 Kein Bock auf Wein-Snobs?
        </p>
        <p style="margin: 0 0 1rem; font-size: 0.9rem;">
          Jeden Freitag eine ehrliche Wein-Empfehlung in deine Inbox.
        </p>
        <form action="https://buttondown.com/api/emails/embed-subscribe/fknwine" method="post" target="popupwindow" onsubmit="window.open('https://buttondown.com/fknwine', 'popupwindow')" style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
          <input
            type="email"
            name="email"
            placeholder="deine@email.de"
            required
            style="padding: 0.6rem 0.75rem; border: 3px solid var(--color-text); background: var(--color-surface); color: var(--color-text); font-family: var(--font-sans); font-size: 0.9rem; min-width: 180px;"
          />
          <button class="brutal-btn" type="submit" style="border-color: var(--color-cta); font-size: 0.85rem;">
            Anmelden
          </button>
        </form>
      </div>
    </footer>
  </article>
</Layout>
